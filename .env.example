VITE_APP_TITLE=PlateForm

# Neon PostgreSQL
DATABASE_URL=your_neon_database_url

# Resend (email / password reset)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Better Auth
BETTER_AUTH_SECRET=random_32+_char_string
BETTER_AUTH_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000

# Telegram token encryption (32-byte hex = 64 chars)
ENCRYPTION_KEY=your_64_char_hex_string

# Telegram webhook secret — set when registering webhook URL with BotFather
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string
